---

import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
interface Props {
  report: CollectionEntry<"news">;
}

const { report } = Astro.props;

const docImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

const memberImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/member/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

function findImage(
  glob: Record<string, { default: ImageMetadata }>,
  name: string
) {
  const entry = Object.entries(glob).find(([path]) =>
    path.split("/").pop()?.split(".")[0] === name
  );
  return entry?.[1].default;
}

const docImg = findImage(docImages, report.data.img);
const authorImg = findImage(memberImages, report.data.authorPic);
---

<div class="appear-anim">
  <article
    class="overflow-hidden rounded-lg programs-card apear-anim shadow-sm transition hover:shadow-lg mb-10 md:mb-0"
  >
    {docImg 
    ? <Image src={docImg} alt={report.data.title} class="h-56 w-full object-cover" />
    : <div class="h-56 w-full object-cover bg-neutralwhite" /> <!-- fallback -->
  }

    <div class="bg-secondary-bright p-4 sm:p-6">
      <time datetime={report.data.date} class="block text-xs text-neutralblack">
        {report.data.date}
      </time>

      <a href="#">
        <h3 class="text-primary-darken font-bold mt-1 text-xl">
          {report.data.title}
        </h3>
      </a>

      <p class="mt-2 line-clamp-3 text-sm/relaxed text-primary">
        {report.data.Description}
      </p>
    </div>
  </article>
</div>
