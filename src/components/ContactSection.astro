---
import whatsappIcon from "../assets/logo/whatsapp.svg?raw";
const key = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    <div class="md:py-4">
      <h2 class="text-2xl font-heading font-bold md:text-6xl sm:text-3xl">
        Hubungi Kami
      </h2>

      <p class="mt-4 font-isi">
        Lorem, ipsum dolor sit amet consectetur adipisicing elit. Sed voluptas
        delectus alias magni velit! Dicta corrupti dignissimos dolor consequatur
        illum tempore consectetur hic a cupiditate sunt quam, earum nisi
        aperiam.
      </p>

      <dl class="mt-6 space-y-3">
        <div>
          <dt class="sr-only">Phone number</dt>

          <dd class="grid grid-cols-[24px_1fr] items-center gap-2">
            <div class="[&>svg]:w-5 [&>svg]:h-5">
              <Fragment
                set:html={whatsappIcon}
                alt="whatsapp"
                loading="eager"
              />
            </div>
            <a
              href="https://wa.me/6289654431972"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="font-medium font-isi"
                >+62 896-5443-1972 (Wulan Maulida Sari)</span
              >
            </a>
          </dd>
        </div>

        <div>
          <dt class="sr-only">Email</dt>

          <dd class="grid grid-cols-[24px_1fr] items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>

            <a href="mailto:himafifst@apps.uinjkt.ac.id">
              <span class="font-medium font-isi"
                >himafifst@apps.uinjkt.ac.id</span
              >
            </a>
          </dd>
        </div>

        <div>
          <dt class="sr-only">Location</dt>

          <dd class="grid grid-cols-[24px_1fr] items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
              ></path>
            </svg>

            <span class="font-medium font-isi"
              >Lt 7 Gedung FST UIN Jakarta, UIN Jakarta, Jl. Lkr. Kampus 1,
              Cempaka Putih, Ciputat Timur, Kota Tangerang Selatan, Banten 15412</span
            >
            <div
              class="lg:w-125 lg:h-100 min-w-20 ml-4 md:ml-0 min-h-20 w-78 h-50 mt-5 rounded-2xl overflow-hidden border-2 border-secondary"
            >
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m13!1m8!1m3!1d305.9455464929487!2d106.752363!3d-6.3065021!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zNsKwMTgnMjMuMyJTIDEwNsKwNDUnMDguNiJF!5e1!3m2!1sid!2sid!4v1780241511123!5m2!1sid!2sid"
                class="w-full h-full"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          </dd>
        </div>
      </dl>
    </div>

    <form
      action="https://api.web3forms.com/submit"
      class="space-y-4 rounded-lg border flex flex-col justify-center border-primary bg-gray-100 p-6"
      method="POST"
    >
      <input type="hidden" name="access_key" value={key} />
      <div>
        <label class="block text-sm font-medium text-primary" for="name"
          >Nama</label
        >

        <input
          class="mt-1 w-full rounded-lg border-2 p-2 border-primary-darken focus:border-green-samanvaya text-primary focus:outline-none"
          id="name"
          name="name"
          type="text"
          placeholder="Namamu atau nama instansi"
          required
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900" for="email"
          >Email</label
        >

        <input
          class="mt-1 w-full rounded-lg border-2 p-2 border-primary-darken focus:border-green-samanvaya text-primary focus:outline-none"
          id="email"
          name="email"
          type="email"
          placeholder="Alamatemailmu@mail.com"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-primary" for="name"
          >Subjek</label
        >

        <input
          class="mt-1 w-full rounded-lg border-2 p-2 border-primary-darken focus:border-green-samanvaya text-primary focus:outline-none"
          id="subject"
          name="subject"
          type="text"
          placeholder="subjek dari pesanmu"
          required
        />
      </div>
      <div class="">
        <label class="block text-sm font-medium text-primary" for="message"
          >Pesan</label
        >

        <textarea
          class="mt-1 w-full p-4 resize-none rounded-lg border-2 border-primary-darken focus:border-green-samanvaya focus:outline-none text-primary-darken"
          id="message"
          name="message"
          rows="4"
          placeholder="Isi pesanmu"></textarea>
      </div>

      <button
        class="block w-full rounded-lg border border-primary-darken bg-primary px-12 py-3 text-sm font-medium text-secondary-bright transition-colors hover:bg-transparent cursor-pointer hover:text-primary"
        type="submit"
      >
        Kirim Pesan
      </button>
    </form>
  </div>
</div>
