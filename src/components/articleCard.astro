---

import type { CollectionEntry } from "astro:content";

const parseDate = (str: string) => {
  const [d, m, y] = str.split("-");
  return new Date(`${y}-${m}-${d}`);
};
import Paragraph from "../components/Paragraph.astro";
const formatDate = (str: string) =>
  parseDate(str).toLocaleDateString("id-ID", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
interface Props {
  report: CollectionEntry<"news">;
}
import { Image } from "astro:assets";
const { report } = Astro.props;

const docImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

const memberImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/author/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

function findImage(
  glob: Record<string, { default: ImageMetadata }>,
  name: string
) {
  const entry = Object.entries(glob).find(([path]) =>
    path.split("/").pop()?.split(".")[0] === name
  );
  return entry?.[1].default;
}


const docImg = findImage(docImages, report.data.img);
const authorImg = findImage(memberImages, report.data.authorPic);
---

<a
  href={`/news/${report.id}`}
  class="group flex gap-3 p-3 rounded-xl hover:bg-[#1A1A2E]/5 transition-colors duration-200"
>
  <!-- Thumbnail -->
  <div
    class="w-20 h-20 shrink-0 rounded-lg overflow-hidden bg-[#1A1A2E]/10"
  >

{docImg ? <Image src={docImg} alt={report.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" onerror="this.parentElement.classList.add('flex','items-center','justify-center'); this.style.display='none'"/>
    : <div class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 " /> <!-- fallback -->
  }
    <!-- Fallback icon jika gambar tidak ada -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-6 h-6 text-[#1A1A2E]/20 hidden"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
      ></path>
    </svg>
  </div>

  <!-- Info -->
  <div class="flex-1 min-w-0 flex flex-col justify-between">
    <div>
      <span
        class="inline-block bg-teritary text-secondary-bright text-[10px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded-sm mb-1"
      >
        {report.data.produced}
      </span>
      <h3
        class="font-['Playfair_Display'] text-sm font-bold text-[#1A1A2E] leading-snug group-hover:text-[#1A1A2E]/70 transition-colors line-clamp-2"
      >
        {report.data.title}
      </h3>
    </div>
    <div class="flex items-center gap-1.5 mt-1.5">
      <!-- Avatar kecil -->
      <div
        class="w-4 h-4 rounded-full bg-[#1A1A2E]/10 overflow-hidden shrink-0"
      >
    {authorImg
      ? <Image src={authorImg} alt={report.data.author} class="w-full h-full object-cover" />
      : <div class="w-full h-full object-cover bg-gray-400" />
    }
      </div>
      <span class="text-[11px] text-[#1A1A2E]/40 truncate"
        >{report.data.author}</span
      >
      <span class="text-[#1A1A2E]/20 text-[11px]">·</span>
      <time class="text-[11px] text-[#1A1A2E]/40 shrink-0">
        {formatDate(report.data.date)}
      </time>
    </div>
  </div>
</a>
