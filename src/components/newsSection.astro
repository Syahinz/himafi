---
import type { CollectionEntry } from "astro:content";
import Section from "./Section.astro";
import H1 from "./H1.astro";
import Paragraph from "./Paragraph.astro";
import { Image } from "astro:assets";
import fotoEkspe from "../assets/images/Ekspedisi.jpg";
import fotoHarry from "../assets/images/Harry.png";
interface Props {
  report: CollectionEntry<"news">;
}

const { report } = Astro.props;

const docImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

const memberImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/member/*.{jpg,jpeg,png,webp}",
  { eager: true },
);

function findImage(
  glob: Record<string, { default: ImageMetadata }>,
  name: string
) {
  const entry = Object.entries(glob).find(([path]) =>
    path.split("/").pop()?.split(".")[0] === name
  );
  return entry?.[1].default;
}

const docImg = findImage(docImages, report.data.img);
const authorImg = findImage(memberImages, report.data.authorPic);
---

<article
  class="flex max-w-xl flex-col items-start justify-between shadow-lg rounded-lg programs-card transition hover:shadow-xl bg-secondary-bright text-primary-darken overflow-hidden"
>
   {docImg 
    ? <Image src={docImg} alt={report.data.title} class="h-56 w-full object-cover" />
    : <div class="h-56  w-full bg-gray-300" /> <!-- fallback -->
  }
    
  <div class="flex items-center gap-x-4 text-xs mt-3 px-6">
    <time datetime={report.data.date} class="">{report.data.date}</time>
    <a
      href="#"
      class="relative z-10 rounded-full bg-primary px-3 py-1.5 font-medium text-secondary hover:bg-primary-darken"
      >{report.data.produced}</a
    >
  </div>

  <div class="group relative grow px-6">
    <h3 class="mt-3 text-lg/6 font-bold group-hover:text-gray-600">
      <a href="#">
        <span class="absolute inset-0"></span>
        {report.data.title}
      </a>
    </h3>
    <p class="mt-5 line-clamp-3 text-sm/6 text-primary">
      {report.data.Description}
    </p>
  </div>
  <div class="relative mt-8 flex items-center gap-x-4 justify-self-end px-6 pb-6">
    {authorImg
      ? <Image src={authorImg} alt={report.data.author} class="size-10 rounded-full" />
      : <div class="size-10 rounded-full bg-gray-400" />
    }
    <div class="text-sm/6 ">
      <p class="font-semibold">
        <a href="#">
          <span class="absolute inset-0"></span>
          {report.data.author}
        </a>
      </p>
      <p class="">{report.data.authorTag}</p>
    </div>
  </div>
</article>
