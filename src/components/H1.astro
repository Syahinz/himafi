---
const { text, spanText = "", mode = "left" } = Astro.props;

const textMode = mode === "center" ? "md:text-center" : "md:text-left";
---

<h1
  class=`font-bold px-3 font-heading text-center ${textMode} lg:text-7xl md:px-9 text-6xl `
>
  {text}<span class="text-green-900">{spanText}</span>
</h1>
