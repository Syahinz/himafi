---
import H1 from "./H1.astro";
import Section from "./Section.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { historyImages, findImage } from "../utils/image";

// Ambil data dari content collection
const historyEntries = await getCollection("history");
const allItems = historyEntries[0]?.data.items ?? [];

// Resolve foto untuk tiap item sebelum split
const resolvedItems = allItems.map((item) => ({
  ...item,
  resolvedPhoto: item.photo ? findImage(historyImages, item.photo) : undefined,
}));

const featured = resolvedItems.find((item) => item.highlight);
const rest = resolvedItems.filter((item) => !item.highlight);
---

<Section direct="sejarah" mode="dark">
  <div class="w-full py-20 px-4 sm:px-8 md:px-16 lg:px-56 flex flex-col gap-10">
    <!-- Header -->
    <H1 text="Sejarah" spanText="HIMAFI" />

    <!-- Featured Card (always visible) -->
    {
      featured && (
        <div class="featured-card bg-primary text-secondary-bright rounded-2xl overflow-hidden appear-anim flex flex-col md:flex-row">
          <!-- Teks kiri -->
          <div class="p-10 flex flex-col justify-center md:w-1/2">
            <span class="text-sm font-isi bg-secondary text-primary-darken py-1 px-3 rounded-full w-fit">
              {featured.era}
            </span>
            <h2 class="text-2xl font-heading font-bold mt-4">{featured.title}</h2>
            <p class="mt-4 font-isi leading-relaxed">{featured.description}</p>
          </div>
          <!-- Foto kanan -->
          <div class="md:w-1/2 shrink-0">
            {featured.resolvedPhoto ? (
              <Image
                src={featured.resolvedPhoto}
                alt={featured.title}
                class="w-full h-60 md:h-full object-cover"
              />
            ) : (
              <div class="w-full h-60 md:h-full bg-primary/30 flex items-center justify-center">
                <span class="font-heading text-5xl font-bold text-secondary-bright/20">
                  {featured.era}
                </span>
              </div>
            )}
          </div>
        </div>
      )
    }

    <!-- Collapsible Area (hidden by default) -->
    <div id="history-rest" class="flex-col gap-6" style="display: none;">
      {
        rest.map((item) => (
          <div class="bg-secondary text-primary-darken rounded-2xl overflow-hidden appear-anim flex flex-col md:flex-row">
            <!-- Teks kiri -->
            <div class="p-8 flex flex-col justify-center md:w-1/2">
              <span class="text-sm font-isi bg-primary text-secondary py-1 px-3 rounded-full w-fit">
                {item.era}
              </span>
              <h3 class="text-xl font-heading font-bold mt-4">{item.title}</h3>
              <p class="mt-3 font-isi leading-relaxed">{item.description}</p>
            </div>
            <!-- Foto kanan -->
            <div class="md:w-1/2 shrink-0">
              {item.resolvedPhoto ? (
                <Image
                  src={item.resolvedPhoto}
                  alt={item.title}
                  class="w-full h-48 md:h-full object-cover"
                />
              ) : (
                <div class="w-full h-48 md:h-full bg-primary/10 flex items-center justify-center">
                  <span class="font-heading text-4xl font-bold text-primary/20">
                    {item.era}
                  </span>
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Toggle Button — style mengikuti CTA.astro -->
    <button
      id="history-toggle"
      class="flex mt-2 justify-center md:justify-start rounded-full bg-secondary-bright text-primary py-4 px-10 text-xl font-heading font-bold transition-all hover:opacity-90 appear-anim cursor-pointer w-fit"
    >
      Lihat Selengkapnya
    </button>
  </div>
</Section>

<script>
  function initHistoryToggle() {
    const area = document.getElementById("history-rest");
    const btn = document.getElementById("history-toggle");

    if (area && btn) {
      // Clone button untuk mencegah duplikasi event listener jika init dipanggil ulang
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);

      newBtn.addEventListener("click", () => {
        const isHidden = area.style.display === "none";
        area.style.display = isHidden ? "flex" : "none";
        newBtn.textContent = isHidden ? "Sembunyikan" : "Lihat Selengkapnya";
      });
    }
  }

  initHistoryToggle();
  document.addEventListener("astro:after-swap", initHistoryToggle);
  document.addEventListener("astro:page-load", initHistoryToggle);
</script>
