---
import Layout from "../layouts/Layout.astro";
import Paragraph from "../components/Paragraph.astro";
import Section from "../components/Section.astro";
import H1 from "../components/H1.astro";
import { Image } from "astro:assets";
import praRaker from "../assets/images/pra-raker.jpg";
const title = `Berita`;
---

<Layout Pagetitle={title}>
  <Section mode="dark">
    <div class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 mt-10 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-auto">
          <H1 text={title} mode="center" />
          <Paragraph
            text="Lihat Berita terupdate di Web HIMAFI"
            mode="center"
          />
        </div>
        <div
          class="mx-auto mt-10 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 border-t border-gray-700 pt-10 sm:mt-16 sm:pt-16 lg:mx-0 lg:max-w-none lg:grid-cols-3"
        >
          <article class="flex max-w-xl flex-col items-start justify-between shadow-lg rounded-lg programs-card transition hover:shadow-xl">
            <Image
              alt="news1"
              src={praRaker}
              class="h-56 my-3 w-full object-cover"
            />
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="2026-05-10" class="">10 Mei, 2026</time>
              <a
                href="#"
                class="relative z-10 rounded-full bg-gray-800/60 px-3 py-1.5 font-medium hover:bg-gray-800"
                >BPH</a
              >
            </div>
            <div class="group relative grow">
              <h3
                class="mt-3 text-lg/6 font-semibold group-hover:text-gray-300"
              >
                <a href="#">
                  <span class="absolute inset-0"></span>
                  Pra-Raker
                </a>
              </h3>
              <p class="mt-5 line-clamp-3 text-sm/6 text-gray-400">
                Illo sint voluptas. Error voluptates culpa eligendi. Hic vel
                totam vitae illo. Non aliquid explicabo necessitatibus unde. Sed
                exercitationem placeat consectetur nulla deserunt vel. Iusto
                corrupti dicta.
              </p>
            </div>
            <div
              class="relative mt-8 flex items-center gap-x-4 justify-self-end"
            >
              <img
                src="https://images.unsplash.com/photo-1519244703995-f4e0f30006d5?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=facearea&facepad=2&w=256&h=256&q=80"
                alt=""
                class="size-10 rounded-full bg-gray-800"
              />
              <div class="text-sm/6">
                <p class="font-semibold text-white">
                  <a href="#">
                    <span class="absolute inset-0"></span>
                    Muhammad Syahin
                  </a>
                </p>
                <p class="text-gray-400">Staff Kominfo</p>
              </div>
            </div>
          </article>

        </div>
      </div>
    </div></Section
  >
</Layout>
