---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import {
  memberImages,
  structureImages,
  findImage,
  programsImages,
} from "../../utils/image";
import Section from "../../components/Section.astro";
export async function getStaticPaths() {
  const departments = await getCollection("departments");
  console.log("departments ditemukan:", departments.length); // kalau 0 = masalahnya di sini
  console.log(
    "ids:",
    departments.map((d) => d.id),
  );
  return departments.map((dept) => ({
    params: { dept: dept.id },
    props: { dept },
  }));
}

const { dept } = Astro.props;

// Resolve foto header departemen
const deptPhoto = findImage(structureImages, dept.data.photo);
const deptSecPhoto = findImage(structureImages, dept.data.secondPhoto);

// Resolve semua foto member

const resolvedMembers = dept.data.members.map((member) => ({
  ...member,
  resolvedPhoto: findImage(memberImages, member.profilePic),
}));
const resolvedPrograms = dept.data.programs.map((program) => ({
  ...program,
  resolvePicture: findImage(programsImages, program.programPic),
}));
---

<Layout Pagetitle={dept.data.name}>
  <!-- Hero foto departemen -->
  {
    deptPhoto && (
      <div class="relative  h-80 w-full overflow-hidden">
        <Image
          src={deptPhoto}
          alt={dept.data.name}
          class="w-full h-full object-cover brightness-75"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 flex flex-col items-center justify-center">
          <h1 class="font-heading font-bold text-5xl text-white">
            {dept.data.name}
          </h1>
          <p class="font-isi text-white/80 mt-2">{dept.data.fullName}</p>
        </div>
      </div>
    )
  }

  <Section>
    <section class="px-4 md:px-10 py-16">
      <p class="font-isi max-w-2xl">{dept.data.description}</p>

      <!-- Grid member -->
      <h2 class="font-heading font-bold text-2xl mt-14 mb-6">Anggota</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
        {
          resolvedMembers.map((member) => (
            <button
              class="text-left group cursor-pointer"
              data-member={JSON.stringify({
                name: member.name,
                role: member.role,
                angkatan: member.angkatan,
                bio: member.bio,
                photo: member.resolvedPhoto?.src ?? "",
              })}
            >
              <div class="overflow-hidden rounded-xl aspect-square bg-primary-darken/10">
                {member.resolvedPhoto ? (
                  <Image
                    src={member.resolvedPhoto}
                    alt={member.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="eager"
                    fetchpriority="high"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center">
                    <span class="font-heading text-2xl font-bold text-primary">
                      {member.name.charAt(0)}
                    </span>
                  </div>
                )}
              </div>
              <p class="mt-2 font-heading font-bold text-sm">{member.name}</p>
              <p class="font-isi text-xs text-primary/60">{member.role}</p>
            </button>
          ))
        }
      </div>

      <!-- Section program kerja (kalau ada) -->
    </section>

    <Section mode="dark">
      <div class="flex justify-center">
        {
          resolvedPrograms.length > 0 && (
            <div class="mt-16 px-6 md:px-16 pb-16">
              <h2 class="font-heading font-bold text-center text-2xl md:text-6xl mb-6">
                Program Kerja
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                {resolvedPrograms.map((program) => (
                  <button
                    class="rounded-xl border border-secondary-bright/20 overflow-hidden text-left cursor-pointer group hover:scale-[1.02] transition-transform duration-300"
                    data-program={JSON.stringify({
                      name: program.name,
                      date: program.date,
                      programDesc: program.programDesc,
                      photo: program.resolvePicture?.src ?? "",
                    })}
                  >
                    <div class="h-48 overflow-hidden bg-primary-darken/30 relative">
                      {program.resolvePicture ? (
                        <Image
                          src={program.resolvePicture}
                          alt={program.name}
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <span class="font-heading text-4xl font-bold text-secondary-bright/30">
                            {program.name.charAt(0)}
                          </span>
                        </div>
                      )}
                    </div>
                    <div class="p-4">
                      <p class="font-heading font-bold text-base text-secondary-bright">
                        {program.name}
                      </p>
                      {program.date && (
                        <p class="font-isi text-xs text-secondary-bright/50 mt-1">
                          {program.date}
                        </p>
                      )}
                    </div>
                  </button>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </Section>

    <div
      id="program-modal"
      class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 items-center justify-center p-4 md:p-10"
      style="display: none"
    >
      <div
        class="relative bg-neutralwhite rounded-3xl w-full max-w-4xl max-h-[80vh] overflow-hidden flex flex-row shadow-2xl"
      >
        <button
          id="close-program-modal"
          class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full bg-primary-darken/60 text-neutralwhite flex items-center justify-center hover:bg-primary-darken transition-colors text-sm font-bold cursor-pointer"
          aria-label="Tutup">✕</button
        >
        <!-- Foto program: selalu kiri -->
        <div
          class="w-5/12 shrink-0 overflow-hidden relative bg-primary-darken/10"
        >
          <img
            id="prog-modal-photo"
            src=""
            alt=""
            class="w-full h-full object-cover"
          />
          <div
            id="prog-modal-fallback"
            class="absolute inset-0 items-center justify-center bg-primary-darken/10"
            style="display: none"
          >
            <span
              id="prog-modal-initial"
              class="font-heading text-6xl font-bold text-primary-darken/30"
            ></span>
          </div>
        </div>
        <!-- Info program: selalu kanan -->
        <div class="w-7/12 flex flex-col overflow-y-auto">
          <div class="p-6 md:p-10 flex flex-col h-full">
            <p
              id="prog-modal-name"
              class="font-heading font-bold text-xl md:text-3xl text-primary-darken leading-tight"
            >
            </p>
            <span
              id="prog-modal-date"
              class="inline-block mt-3 text-xs font-isi bg-primary/10 text-primary px-3 py-1 rounded-full w-fit"
            ></span>
            <hr class="my-4 md:my-6 border-primary/10" />
            <p
              id="prog-modal-desc"
              class="font-isi text-xs md:text-base leading-relaxed text-primary-darken flex-1"
            >
            </p>
            <!-- Placeholder kalau desc kosong -->
            <p
              id="prog-modal-empty"
              class="font-isi text-sm text-primary/30 italic flex-1"
              style="display: none"
            >
              Detail program belum tersedia.
            </p>
          </div>
        </div>
      </div>
    </div>
    <!-- Modal — wajib ada class "hidden" di sini -->
    <div
      id="member-modal"
      class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 items-center justify-center p-4 md:p-10"
      style="display: none"
    >
      <div
        class="relative bg-neutralwhite rounded-3xl w-full max-w-4xl max-h-[80vh] overflow-hidden flex flex-row shadow-2xl"
      >
        <button
          id="close-modal"
          class="absolute top-4 right-4 z-20 w-9 h-9 rounded-full bg-primary-darken/60 text-neutralwhite flex items-center justify-center hover:bg-primary-darken transition-colors text-sm font-bold cursor-pointer"
          aria-label="Tutup">✕</button
        >
        <!-- Foto: selalu kiri -->
        <div
          class="w-5/12 shrink-0 overflow-hidden relative bg-primary-darken/10"
        >
          <img
            id="modal-photo"
            src=""
            alt=""
            class="w-full h-full object-cover object-top"
          />
          <div
            id="modal-photo-fallback"
            class="absolute inset-0 items-center justify-center bg-primary-darken/20"
            style="display: none"
          >
            <span
              id="modal-photo-initial"
              class="font-heading text-6xl font-bold text-primary-darken/40"
            ></span>
          </div>
        </div>
        <!-- Info: selalu kanan -->
        <div class="w-7/12 flex flex-col overflow-y-auto">
          <div class="p-6 md:p-10 flex flex-col h-full">
            <div>
              <p
                id="modal-name"
                class="font-heading font-bold text-xl md:text-3xl text-primary-darken leading-tight"
              >
              </p>
              <p
                id="modal-role"
                class="font-isi text-primary/60 mt-2 text-xs md:text-base"
              >
              </p>
              <span
                id="modal-angkatan"
                class="inline-block mt-3 text-xs font-isi bg-primary/10 text-primary px-3 py-1 rounded-full"
              ></span>
            </div>
            <hr class="my-4 md:my-6 border-primary/10" />
            <p
              id="modal-bio"
              class="font-isi text-xs md:text-base leading-relaxed text-primary-darken flex-1"
            >
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <script>
    const memberModal = document.getElementById("member-modal")! as HTMLElement;
    const closeBtn = document.getElementById("close-modal")!;
    const programModal = document.getElementById(
      "program-modal",
    )! as HTMLElement;
    const closeProgramBtn = document.getElementById("close-program-modal")!;

    // ── Member modal ──────────────────────────────
    function openModal(data: {
      name: string;
      role: string;
      angkatan?: string;
      bio: string;
      photo?: string;
    }) {
      const photoEl = document.getElementById(
        "modal-photo",
      ) as HTMLImageElement;
      const fallback = document.getElementById("modal-photo-fallback")!;
      const initial = document.getElementById("modal-photo-initial")!;

      document.getElementById("modal-name")!.textContent = data.name;
      document.getElementById("modal-role")!.textContent = data.role;
      document.getElementById("modal-bio")!.textContent = data.bio;

      const angkatanEl = document.getElementById(
        "modal-angkatan",
      )! as HTMLElement;
      angkatanEl.textContent = data.angkatan ? `Angkatan ${data.angkatan}` : "";
      angkatanEl.style.display = data.angkatan ? "inline-block" : "none";

      if (data.photo) {
        photoEl.src = data.photo;
        photoEl.alt = data.name;
        photoEl.style.display = "block";
        fallback.style.display = "none";
      } else {
        photoEl.style.display = "none";
        fallback.style.display = "flex";
        initial.textContent = data.name.charAt(0);
      }

      memberModal.style.display = "flex";
      document.body.style.overflow = "hidden";
    }

    function closeModal() {
      memberModal.style.display = "none";
      document.body.style.overflow = "";
    }

    // ── Program modal ─────────────────────────────
    function openProgramModal(data: {
      name: string;
      date?: string;
      programDesc?: string;
      photo?: string;
    }) {
      const photoEl = document.getElementById(
        "prog-modal-photo",
      ) as HTMLImageElement;
      const fallback = document.getElementById("prog-modal-fallback")!;
      const initial = document.getElementById("prog-modal-initial")!;
      const descEl = document.getElementById("prog-modal-desc")! as HTMLElement;
      const emptyEl = document.getElementById(
        "prog-modal-empty",
      )! as HTMLElement;
      const dateEl = document.getElementById("prog-modal-date")! as HTMLElement;

      document.getElementById("prog-modal-name")!.textContent = data.name;

      dateEl.textContent = data.date ?? "";
      dateEl.style.display = data.date ? "inline-block" : "none";

      if (data.programDesc) {
        descEl.textContent = data.programDesc;
        descEl.style.display = "block";
        emptyEl.style.display = "none";
      } else {
        descEl.style.display = "none";
        emptyEl.style.display = "block";
      }

      if (data.photo) {
        photoEl.src = data.photo;
        photoEl.alt = data.name;
        photoEl.style.display = "block";
        fallback.style.display = "none";
      } else {
        photoEl.style.display = "none";
        fallback.style.display = "flex";
        initial.textContent = data.name.charAt(0);
      }

      programModal.style.display = "flex";
      document.body.style.overflow = "hidden";
    }

    function closeProgramModal() {
      programModal.style.display = "none";
      document.body.style.overflow = "";
    }

    // ── Listeners ─────────────────────────────────
    function attachListeners() {
      document.querySelectorAll("[data-member]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const data = JSON.parse((btn as HTMLElement).dataset.member!);
          openModal(data);
        });
      });

      document.querySelectorAll("[data-program]").forEach((btn) => {
        btn.addEventListener("click", () => {
          const data = JSON.parse((btn as HTMLElement).dataset.program!);
          openProgramModal(data);
        });
      });
    }

    closeBtn.addEventListener("click", closeModal);
    memberModal.addEventListener("click", (e) => {
      if (e.target === memberModal) closeModal();
    });

    closeProgramBtn.addEventListener("click", closeProgramModal);
    programModal.addEventListener("click", (e) => {
      if (e.target === programModal) closeProgramModal();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeModal();
        closeProgramModal();
      }
    });

    attachListeners();
    document.addEventListener("astro:after-swap", attachListeners);
  </script>
</Layout>
