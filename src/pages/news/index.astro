---
import Layout from "../../layouts/Layout.astro";
import Paragraph from "../../components/Paragraph.astro";
import Section from "../../components/Section.astro";
import H1 from "../../components/H1.astro";
import { sortNewsByDate } from "../../utils/date.ts";
import { getCollection } from "astro:content";
const title = `Berita`;
import NewsSection from "../../components/newsSection.astro";

const news = await getCollection("news");
const sorted = sortNewsByDate(news);
---

<Layout Pagetitle={title}>
  <Section mode="dark">
    <div class="py-24 sm:py-32">
      <div class="mx-auto max-w-7xl px-6 mt-10 lg:px-8">
        <div class="mx-auto max-w-2xl lg:mx-auto">
          <H1 text={title} mode="center" />
          <Paragraph
            text="Lihat Berita terupdate di Web HIMAFI"
            mode="center"
          />
        </div>
        <div
          class="mx-auto mt-10 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 border-t border-secondary-bright pt-10 sm:mt-16 sm:pt-16 lg:mx-0 lg:max-w-none lg:grid-cols-3"
        >
          <!-- news card section -->
          {sorted.map((report) => <NewsSection report={report} />)}
          {sorted.length < 1 && <Paragraph text="Ga ada berita kawan " />}
          <!-- news card section end -->
        </div>
      </div>
    </div>
  </Section>
</Layout>
