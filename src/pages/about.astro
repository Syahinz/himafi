---
import Layout from "../layouts/Layout.astro";
import Section from "../components/Section.astro";
import H1 from "../components/H1.astro";
import Paragraph from "../components/Paragraph.astro";
const title = `Tentang`;
---

<Layout Pagetitle={title}>
  <Section>
    <div class="pt-36 px-4 sm:px-8 md:px-16 lg:px-72">
      <H1 text="TENTANG" mode="center" />
      <Paragraph
        text="HIMAFI bukan sekadar organisasi, tetapi ruang bagi mahasiswa fisika untuk belajar, berkolaborasi, dan berkembang bersama. dengan semangat sinergi dan kebersamaan, HIMAFI hadir untuk mengembangkan potensi anggota serta memberi dampak positif bagi lingkungan akademik dan masyarakat."
        mode="center"
      />
    </div>
  </Section>
</Layout>
